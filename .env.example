# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Auth — shared access code + signed cookie
ACCESS_CODE=zmen_ma_na_nieco_nahodne
SESSION_SECRET=generate_with_openssl_rand_base64_32

# Voliteľné: zoznam povolených domén pre email pri prihlásení (honor system).
# Ak nastavíš `dius.ai`, prijme len emaily končiace @dius.ai.
# Nechaj prázdne pre žiadne obmedzenie.
ALLOWED_DOMAIN=dius.ai
